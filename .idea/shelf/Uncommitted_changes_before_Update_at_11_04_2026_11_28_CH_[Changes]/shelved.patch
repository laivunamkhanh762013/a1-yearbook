<+><!DOCTYPE html>\r\n<html lang=\"vi\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<title>Quiz 7A1</title>\r\n\r\n<style>\r\nbody {\r\n  font-family: Arial;\r\n  text-align: center;\r\n  background: #f0f0f0;\r\n}\r\n\r\n.quiz-box {\r\n  width: 500px;\r\n  margin: 30px auto;\r\n  background: #fff;\r\n  padding: 20px;\r\n  border-radius: 10px;\r\n  transition: 0.2s;\r\n}\r\n\r\n.quiz-box img {\r\n  width: 100%;\r\n  border-radius: 10px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.btn {\r\n  display:block;\r\n  margin:10px auto;\r\n  padding:10px;\r\n  background:#4CAF50;\r\n  color:white;\r\n  border-radius:5px;\r\n  cursor:pointer;\r\n  width:80%;\r\n}\r\n\r\n.btn:hover { background:#45a049; }\r\n\r\n/* rung */\r\n.shake { animation: shake 0.3s; }\r\n@keyframes shake {\r\n  25% { transform: translateX(-5px); }\r\n  50% { transform: translateX(5px); }\r\n  75% { transform: translateX(-5px); }\r\n}\r\n\r\n/* popup */\r\n#popup {\r\n  position: fixed;\r\n  top:0; left:0;\r\n  width:100%; height:100%;\r\n  background: rgba(0,0,0,0.5);\r\n  display:none;\r\n  justify-content:center;\r\n  align-items:center;\r\n}\r\n\r\n.popup-content {\r\n  background:white;\r\n  padding:25px;\r\n  border-radius:15px;\r\n  text-align:center;\r\n  animation: zoomIn 0.3s;\r\n}\r\n\r\n@keyframes zoomIn {\r\n  from { transform: scale(0.7); opacity:0; }\r\n  to { transform: scale(1); opacity:1; }\r\n}\r\n</style>\r\n</head>\r\n\r\n<body>\r\n\r\n<div class=\"quiz-box\" id=\"quizBox\">\r\n  <img id=\"quizImage\" src=\"lop.jpg\">\r\n  <h2 id=\"question\"></h2>\r\n\r\n  <button class=\"btn\" onclick=\"checkAnswer('A')\" id=\"A\"></button>\r\n  <button class=\"btn\" onclick=\"checkAnswer('B')\" id=\"B\"></button>\r\n  <button class=\"btn\" onclick=\"checkAnswer('C')\" id=\"C\"></button>\r\n  <button class=\"btn\" onclick=\"checkAnswer('D')\" id=\"D\"></button>\r\n</div>\r\n\r\n<!-- popup -->\r\n<div id=\"popup\">\r\n  <div class=\"popup-content\">\r\n    <h2 id=\"popupText\"></h2>\r\n  </div>\r\n</div>\r\n\r\n<script>\r\n// câu hỏi\r\nconst questions = [\r\n  {\r\n    question: \"Hiện tại, lớp trưởng lớp 7A1 là ai?\",\r\n    image: \"lop.jpg\",\r\n    options: [\r\n      \"Trần Anh Khôi\",\r\n      \"Trần Gia Linh\",\r\n      \"Lê Minh Khang\",\r\n      \"Nguyễn Vũ Bảo An\"\r\n    ],\r\n    answer: \"B\"\r\n  },\r\n  {\r\n    question: \"Lớp 7A1 có cô giáo chủ nhiệm tên gì?\",\r\n    image: \"Teacher.jpg\",\r\n    options: [\r\n      \"Cô Lan\",\r\n      \"Cô Hương\",\r\n      \"Cô Linh\",\r\n      \"Cô Thảo\"\r\n    ],\r\n    answer: \"C\"\r\n  },\r\n  {\r\n    question: \"Lớp mình có số phòng là?\",\r\n    image: \"lop.jpg\",\r\n    options: [\r\n      \"D303\",\r\n      \"D305\",\r\n      \"D207\",\r\n      \"D301\"\r\n    ],\r\n    answer: \"D\"\r\n  },\r\n  {\r\n    question: \"Lớp 7A1 có bao nhiêu Nam và Nữ?\",\r\n    image: \"lop.jpg\",\r\n    options: [\r\n      \"19 Nam và 23 Nữ\",\r\n      \"18 Nam và 25 Nữ\",\r\n      \"67 Nam và 36 Nữ\",\r\n      \"20 Nam và 22 Nữ\"\r\n    ],\r\n    answer: \"A\"\r\n  },\r\n  {\r\n    question: \"Hiện tại GVCN lớp 7A1 đang dạy môn gì?\",\r\n    image: \"Teacher.jpg\",\r\n    options: [\r\n      \"Sử\",\r\n      \"Toán\",\r\n      \"Ngữ Văn\",\r\n      \"KHTN\"\r\n    ],\r\n    answer: \"A\"\r\n  }\r\n];\r\n\r\n// \uD83D\uDD25 RANDOM CÂU HỎI\r\nquestions.sort(() => Math.random() - 0.5);\r\n\r\nlet current = 0;\r\n\r\n// load câu hỏi\r\nfunction loadQuestion() {\r\n  let q = questions[current];\r\n\r\n  document.getElementById(\"question\").innerText = q.question;\r\n  document.getElementById(\"quizImage\").src = q.image;\r\n\r\n  document.getElementById(\"A\").innerText = \"A. \" + q.options[0];\r\n  document.getElementById(\"B\").innerText = \"B. \" + q.options[1];\r\n  document.getElementById(\"C\").innerText = \"C. \" + q.options[2];\r\n  document.getElementById(\"D\").innerText = \"D. \" + q.options[3];\r\n}\r\n\r\n// popup\r\nfunction showPopup(text) {\r\n  const popup = document.getElementById(\"popup\");\r\n  document.getElementById(\"popupText\").innerText = text;\r\n  popup.style.display = \"flex\";\r\n}\r\n\r\nfunction hidePopup() {\r\n  document.getElementById(\"popup\").style.display = \"none\";\r\n}\r\n\r\n// check\r\nfunction checkAnswer(ans) {\r\n  let quiz = document.getElementById(\"quizBox\");\r\n\r\n  if(ans === questions[current].answer) {\r\n    showPopup(\"✔\uFE0F Chính xác!\");\r\n\r\n    setTimeout(() => {\r\n      hidePopup();\r\n      current++;\r\n\r\n      if(current < questions.length) {\r\n        loadQuestion();\r\n      } else {\r\n        showPopup(\"\uD83C\uDF89 Bạn là học sinh lớp 7A1 rùi nè =))\");\r\n\r\n        setTimeout(() => {\r\n          window.location.href = \"main.html\";\r\n        }, 1500);\r\n      }\r\n    }, 1000);\r\n\r\n  } else {\r\n    showPopup(\"❌ Sai rồi! Chọn lại nhé!\");\r\n\r\n    quiz.classList.add(\"shake\");\r\n    setTimeout(() => quiz.classList.remove(\"shake\"), 300);\r\n\r\n    setTimeout(hidePopup, 1000);\r\n  }\r\n}\r\n\r\nloadQuestion();\r\n</script>\r\n\r\n</body>\r\n</html>
